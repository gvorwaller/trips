# trips environment variables.
# Copy to .env and fill in real values for local dev.
# Production .env lives on the droplet at /opt/trips/.env (mode 600, root:root).

# --- Runtime (loaded by the SvelteKit web app process) ---
PGHOST=127.0.0.1
PGPORT=5437
PGDATABASE=trips
PGUSER=trips_app
PGPASSWORD=

# --- Migration-only (loaded by backend/db/migrate_pg.sh, NOT by the web app) ---
MIGRATION_PGUSER=trips_owner
MIGRATION_PGPASSWORD=

# --- App secrets ---
AUTH_SECRET=

# --- Google Maps (public client-side key shared with gaylon.photos) ---
PUBLIC_GOOGLE_MAPS_API_KEY=
PUBLIC_GOOGLE_MAPS_MAP_ID=
# Server-side geocoding key (place search + reverse geocode), from gaylonphotos/.env
GOOGLE_GEOCODING_KEY=

# --- DO Spaces (PRIVATE bucket for trip attachments; app-proxied downloads) ---
# Distinct from gaylonphotos' public bucket. Objects use private ACL; the app
# streams downloads through an authenticated route (no public/CDN URL).
SPACES_KEY=
SPACES_SECRET=
SPACES_BUCKET=
SPACES_REGION=sfo3
SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com

PORT=5179
NODE_ENV=development
